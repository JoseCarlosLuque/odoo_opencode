<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_line_tree_inherit" model="ir.ui.view">
        <field name="name">purchase.order.line.tree.inherit.board</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_uom']" position="after">
                <field name="board_format_id" optional="hide"/>
                <field name="board_area" optional="hide" widget="float" sum="Total Area"/>
            </xpath>
        </field>
    </record>

    <record id="view_purchase_order_line_form_inherit" model="ir.ui.view">
        <field name="name">purchase.order.line.form.inherit.board</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_uom']" position="after">
                <field name="board_format_id"/>
                <field name="board_area" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>