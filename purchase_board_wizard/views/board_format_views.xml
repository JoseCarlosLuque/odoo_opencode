    <record id="action_board_format" model="ir.actions.act_window">
        <field name="name">Board Formats</field>
        <field name="res_model">board.format</field>
        <field name="view_mode">list,form,search</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <menuitem id="menu_board_format" name="Board Formats" parent="purchase.menu_purchase_config" action="action_board_format" sequence="100"/>
</odoo>