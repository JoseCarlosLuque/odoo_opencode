<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_board_format_tree" model="ir.ui.view">
        <field name="name">board.format.tree</field>
        <field name="model">board.format</field>
        <field name="arch" type="xml">
            <list string="Board Formats">
                <field name="product_id"/>
                <field name="name"/>
                <field name="area"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_board_format_form" model="ir.ui.view">
        <field name="name">board.format.form</field>
        <field name="model">board.format</field>
        <field name="arch" type="xml">
            <form string="Board Format">
                <sheet>
                    <group>
                        <field name="product_id"/>
                        <field name="name"/>
                        <field name="area"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

